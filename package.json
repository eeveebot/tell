{
  "name": "@eeveebot/tell",
  "version": "2.2.15",
  "description": "tell module for eevee.bot",
  "main": "dist/main.mjs",
  "type": "module",
  "scripts": {
    "build": "npm run test && tsc",
    "dev": "tsc --watch & node --loader ts-node/esm src/main.mts",
    "test": "eslint src/",
    "migrate": "node --loader ts-node/esm src/migrate.mts",
    "update-libraries": "ncu -u @eeveebot/libeevee js-yaml undici better-sqlite3 && npm install"
  },
  "dependencies": {
    "@eeveebot/libeevee": "^3.3.1",
    "better-sqlite3": "^12.8.0",
    "irc-colors": "^1.5.0",
    "js-yaml": "^4.1.1",
    "undici": "^7.24.2",
    "youtube-node": "^1.3.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.0.0",
    "globals": "^17.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
